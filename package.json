{
  "name": "figma-assets",
  "version": "0.2.0",
  "description": "Extract production-ready SVG and raster assets from Figma",
  "type": "module",
  "bin": {
    "figma-assets": "./dist/index.js"
  },
  "main": "./dist/extract.js",
  "types": "./dist/extract.d.ts",
  "exports": {
    ".": {
      "types": "./dist/extract.d.ts",
      "default": "./dist/extract.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "keywords": [
    "figma",
    "svg",
    "assets",
    "icons",
    "design-to-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JungHoonGhae/figma-assets"
  },
  "files": [
    "dist",
    "README.md",
    "README.ko.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  }
}
